{
  "version": "0.2.0",
  "configurations": [
    // ── Backend: FastAPI (uvicorn) ────────────────────────────────────
    {
      "name": "Backend: FastAPI Dev",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "jinja": true,
      "justMyCode": false,
      "console": "integratedTerminal"
    },

    // ── Backend: Pytest ───────────────────────────────────────────────
    {
      "name": "Backend: Pytest (Tüm Testler)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "--tb=short"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "console": "integratedTerminal"
    },

    // ── Mobile: Expo (Android) ────────────────────────────────────────
    {
      "name": "Mobile: Expo Android",
      "type": "reactnative",
      "request": "launch",
      "platform": "android",
      "cwd": "${workspaceFolder}/mobile_app"
    },

    // ── Mobile: Expo (iOS Simulator) ──────────────────────────────────
    {
      "name": "Mobile: Expo iOS",
      "type": "reactnative",
      "request": "launch",
      "platform": "ios",
      "cwd": "${workspaceFolder}/mobile_app"
    },

    // ── Mobile: Expo Go (Fiziksel Cihaz) ──────────────────────────────
    {
      "name": "Mobile: Expo Go (Cihaz)",
      "type": "reactnative",
      "request": "launch",
      "platform": "exponent",
      "cwd": "${workspaceFolder}/mobile_app"
    }
  ],

  "compounds": [
    {
      "name": "Full Stack: Backend + Mobile",
      "configurations": ["Backend: FastAPI Dev", "Mobile: Expo Android"],
      "stopAll": true
    }
  ]
}
