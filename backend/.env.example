# Application
APP_NAME=LinguaAI
APP_ENV=development
DEBUG=true
# openssl rand -hex 32 ile üret
SECRET_KEY=change-me-use-openssl-rand-hex-32

# MongoDB
MONGO_URI=mongodb://admin:secret@localhost:27017/langlearn?authSource=admin
MONGO_DB=langlearn

# AI Provider — set ONE of the following
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Choose provider: "openai" | "anthropic"
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
